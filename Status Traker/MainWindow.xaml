<Window x:Class="Status_Traker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Status_Traker"
        xmlns:viewmodel="clr-namespace:Status_Traker.ViewModels"
        xmlns:model="clr-namespace:Status_Traker.Models"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.DataContext>
        <viewmodel:MainViewModel />      
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Status Filter:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox Width="150"
                      ItemsSource="{Binding AvailableStatuses}"
                      SelectedItem="{Binding StatusFilter}"
                      IsEditable="False"/>
          
        </StackPanel>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Jobs}"
                  SelectedItem="{Binding SelectedJob}"
                  AutoGenerateColumns="False"
                  IsReadOnly="False">
            <DataGrid.Columns>
                <!--<DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>-->
                <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="120"/>
                <DataGridTextColumn Header="Year" Binding="{Binding Year}" Width="100"/>
                <DataGridTextColumn Header="Make" Binding="{Binding Make}" Width="100"/>
                <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="100"/>
                <DataGridTextColumn Header="Repair Center" Binding="{Binding RepairCenter}" Width="100"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" IsReadOnly="True" Width="100"/>
                <!--<DataGridComboBoxColumn Header="Status"
                                        SelectedItemBinding="{Binding Status}"
                                        ItemsSource="{Binding DataContext.AvailableStatuses,
                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                        Width="120"/>-->
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <TextBlock Text="Selected Job Status:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBlock Text="{Binding SelectedJob.Status}" FontWeight="Bold" VerticalAlignment="Center"/>

            <TextBlock Text="Status Filter:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox Width="150"
          ItemsSource="{Binding AvailableStatuses}"
          SelectedItem="{Binding StatusUpdate}"
          IsEditable="False"/>

            <Button Content="Apply"
            Margin="10,0,0,0"
            Command="{Binding SetStatusCommand}"
            CommandParameter="{Binding StatusUpdate}" />

         
        </StackPanel>
    </Grid>
</Window>
